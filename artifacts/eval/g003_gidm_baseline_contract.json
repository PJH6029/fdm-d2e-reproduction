  "official_metric_protocol": {
    "bin_ms": 50,
    "empty_bins_as_correct": false,
    "mouse_move": "sum dx/dy per 50ms bin; report pearson_x, pearson_y, scale_ratio_x, scale_ratio_y",
    "mouse_button": "exact per-button count match per 50ms bin; report button_accuracy",
    "keyboard": "exact press/release virtual-key count match per 50ms bin; report key_accuracy",
    "mouse_scroll": "exact scroll amount match per 50ms bin",
    "autoregressive": true,
    "teacher_forcing": false,
    "local_metric_mapping": {
      "keyboard_accuracy": "official keyboard.key_accuracy",
      "mouse_button_accuracy": "official mouse_button.button_accuracy",
      "mouse_button_f1": "local postprocessor over official predicted MCAP bins; not a paper-reported metric",
      "mouse_move_pearson": "mean of official mouse_move.pearson_x and mouse_move.pearson_y unless split report keeps axes separate",
      "mouse_scale_ratio": "mean of official scale_ratio_x and scale_ratio_y plus axis-specific values"
    }
