{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["schema", "dataset", "source_mode", "hf_repo_id", "revision", "license", "source_contract", "recordings", "splits", "event_categories", "dataset_fingerprint"],
  "properties": {
    "schema": {"type": "string", "enum": ["data_manifest.v2"]},
    "dataset": {"type": "string"},
    "source_mode": {"type": "string"},
    "hf_repo_id": {"type": "string"},
    "revision": {"type": "string"},
    "license": {"type": "string"},
    "source_contract": {"type": "object"},
    "recordings": {"type": "array", "items": {"type": "object"}},
    "splits": {"type": "object"},
    "event_categories": {"type": "array", "items": {"type": "string"}},
    "dataset_fingerprint": {"type": "string"}
  }
}
